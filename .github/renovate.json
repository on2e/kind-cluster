{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>on2e/renovate-config",
    ":automergeMinor",
    ":automergeDigest",
    ":skipStatusChecks"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update KIND node image in KIND_NODE_IMAGE file",
      "managerFilePatterns": ["/^KIND_NODE_IMAGE$/"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker",
      "matchStrings": [
        "(?<depName>kindest/node):(?<currentValue>v\\d+\\.\\d+\\.\\d+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Pin digests for KIND node images",
      "matchPackageNames": ["/^kindest/node$/"],
      "matchDatasources": ["docker"],
      "pinDigests": true
    },
    {
      "description": "Use `<app-name>` as semantic commit scope for updates in the `deployments/<app-name>` directory",
      "matchFileNames": ["deployments/*/**"],
      "semanticCommitScope": "{{{ lookup (split packageFileDir '/') 1 }}}",
      "branchTopic": "{{{semanticCommitScope}}}-{{{newMajor}}}{{#if separateMinorPatch}}{{#if isPatch}}.{{{newMinor}}}{{/if}}{{/if}}{{#if separateMultipleMinor}}{{#if isMinor}}.{{{newMinor}}}{{/if}}{{/if}}.x",
      "commitMessageTopic": "dependency references",
      "group": {
        "branchTopic": "{{{groupSlug}}}",
        "commitMessageTopic": "dependency references"
      }
    },
    {
      "description": "Use SemVer versioning for Ingress NGINX updates",
      "matchPackageNames": ["/^kubernetes/ingress-nginx$/"],
      "matchDatasources": ["github-tags"],
      "versionCompatibility": "^(?<compatibility>controller)-(?<version>.+)$",
      "versioning": "semver"
    }
  ]
}
